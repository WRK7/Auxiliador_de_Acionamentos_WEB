# ===========================================
# Backend - Auxiliador de Acionamentos
# Copie para .env e preencha os valores.
# Nunca commite o arquivo .env (ele está no .gitignore).
# ===========================================

# --- Servidor ---
PORT=3089

# Origens permitidas para CORS (URLs do frontend separadas por vírgula).
# Ex.: http://localhost:3088 em dev; em rede pode incluir http://10.100.20.137:3088
# CORS_ORIGIN=http://localhost:3088,http://10.100.20.137:3088

# --- MariaDB ---
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=sua_senha_aqui
DB_NAME=auxiliador_acionamentos

# --- Scripts (opcional: criar/atualizar super admin) ---
# SUPER_ADMIN_USUARIO=email@exemplo.com
# SUPER_ADMIN_SENHA=senha_segura
# SUPER_ADMIN_NOME=Nome do Admin
# SUPER_ADMIN_NOVO_USUARIO=novo_login
