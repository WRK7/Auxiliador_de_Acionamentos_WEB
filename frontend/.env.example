# ===========================================
# Frontend - Auxiliador de Acionamentos
# Copie para .env e ajuste se precisar.
# Nunca commite o arquivo .env (ele está no .gitignore).
# ===========================================

# --- API ---
# Deixe vazio para usar o proxy do Vite em dev (recomendado: evita CORS e "failed to fetch").
# Ou use a URL direta do backend, ex.: http://localhost:3089
# Produção: use a URL real do backend
VITE_API_URL=

# --- Dev (opcional) ---
# Porta do Vite (padrão no vite.config: 3088)
# VITE_DEV_PORT=3088
