# --- API ---
# URL base do backend (sem barra no final).
# Desenvolvimento: http://localhost:3089
# Produção: use a URL real do seu backend
VITE_API_URL=http://localhost:3089

# --- Dev (opcional) ---
# Porta do Vite (padrão no vite.config: 3088)
# VITE_DEV_PORT=3088
